@import '../../theme';

$gap = 1em;
$borderRadiusFactor = 2;

.popupContent
  min-width fit-content

.content
  padding .5em

  .range &
    display flex
    flex-direction row
    flex-wrap nowrap
    gap $gap

.doubleCalendar .calendar
  width 50%

.size-xs
  border-radius 'calc(%s * 1.5)' % $borderRadiusXS !important

  .content
    padding $controlPaddingXS
    min-width 10em

    .doubleCalendar&
      min-width 'calc(20em + %s)' % $gap

.size-s
  border-radius 'calc(%s * 1.5)' % $borderRadiusS !important

  .content
    padding $controlPaddingS
    min-width 12em

    .doubleCalendar&
      min-width 'calc(24em + %s)' % $gap

.size-m
  border-radius 'calc(%s * 1.5)' % $borderRadiusM !important

  .content
    padding $controlPaddingM
    min-width 16em

    .doubleCalendar&
      min-width 'calc(32em + %s)' % $gap

.size-l
  border-radius 'calc(%s * 1.5)' % $borderRadiusL !important

  .content
    padding $controlPaddingL
    min-width 20em

    .doubleCalendar&
      min-width 'calc(40em + %s)' % $gap

.size-xl
  border-radius 'calc(%s * 1.5)' % $borderRadiusXL !important

  .content
    padding $controlPaddingXL
    min-width 24em

    .doubleCalendar&
      min-width 'calc(48em + %s)' % $gap
