@import '../../theme'
json('./Input.constants.json')

$controlHeight = 34px
$paddingSide = 12px

.root
  position relative
  color var(--accent-color)

  &.isTextArea
    max-height 10em

.root
.main
  width 100%

.root
.controlWrapper
  max-width 100%

.main
  position relative
  display flex
  max-width 100%
  border-radius inherit

  &.clearPaddingRight
    padding-right 0 !important
  &.clearPaddingLeft
    padding-left 0 !important

  .isTextArea &
    height auto // !important
    max-height inherit !important

    // padding for scrollbar
    // .size-xs&
    //   padding-right 4px !important;
    // .size-s&
    //   padding-right 5px !important;
    // .size-m&
    //   padding-right 7px !important;
    // .size-l&
    //   padding-right 11px !important;
    // .size-xl&
    //   padding-right 13px !important;

.border
  z-index 0
  position absolute
  top 0
  left 0
  right 0
  bottom 0

  transition 0.15s ease-out
  transition-property box-shadow, border-color, background-color //, clip-path
  background-color var(--accent-color-alpha-100)
  border-radius inherit
  pointer-events none

  .root:hover &
    background-color var(--active-color-alpha-100)

  .variant-clean &
    background-color transparent

    .isFocused&
      controlButtonVariantFocus('default')

  .variant-default &
    controlButtonVariant('default')

    .isFocused&
      controlButtonVariantFocus('default')

  .variant-outlined &
    controlButtonVariant('outlined')

    .isFocused&
      controlButtonVariantFocus('outlined')

    .hasError &
    .hasError:hover &
      outline(var(--danger-color))

    .isFocused.hasError&
      controlFocus(var(--danger-color))

    .isDisabled&
      outline(false, !important)
      controlFocus(false, !important)

.size-xs
  controlFontSize('xs')

  .main
    controlSize('xs')
    controlFontSize('xs')
    borderRadiusSize('xs')
    controlPaddingSize('xs')
    padding-right 0

    .round&
      borderRadiusRoundSize('xs')

.size-s
  controlFontSize('s')

  .main
    controlSize('s')
    controlFontSize('s')
    borderRadiusSize('s')
    controlPaddingSize('s')
    padding-right 0

    .round&
      borderRadiusRoundSize('s')

.size-m
  controlFontSize('m')

  .main
    controlSize('m')
    controlFontSize('m')
    borderRadiusSize('m')
    controlPaddingSize('m')
    padding-right 0

    .round&
      borderRadiusRoundSize('m')

.size-l
  controlFontSize('l')

  .main
    controlSize('l')
    controlFontSize('l')
    borderRadiusSize('l')
    controlPaddingSize('l')
    padding-right 0

    .round&
      borderRadiusRoundSize('l')

.size-xl
  controlFontSize('xl')

  .main
    controlSize('xl')
    controlFontSize('xl')
    borderRadiusSize('xl')
    controlPaddingSize('xl')
    padding-right 0

    .round&
      borderRadiusRoundSize('xl')

// .isTextArea
//   .main
//     padding-left 0

.isDisabled
  color var(--accent-color-alpha-500)
  opacity .4

.control
.addonLeft
.addonRight
  font-size inherit
  font-weight normal

.labelGap
  position absolute
  opacity 0
  pointer-events none

.label
  .isTextArea &
    max-height 40px

.scroller
  width 100%
  max-height 100%

.controlWrapper
  flex 1

.control
  filter none // remove browser(Frefox) autofill-styles
  appearance none
  display inline-flex
  flex-grow 1
  position relative

  height 100%
  width 100%
  min-width 30px
  text-overflow ellipsis

  box-shadow none
  background none
  color inherit
  outline none
  transition border-color 0.15s ease-in-out 0s

  // remove browser(Chrome) autofill-styles
  &:-internal-autofill-selected
  &:-webkit-autofill
    animation-name clearBg
    animation-fill-mode both

  .size-xs &
    padding-right 10px
  .size-s &
    padding-right 12px
  .size-m &
    padding-right 16px
  .size-l &
    padding-right 20px
  .size-xl &
    padding-right 22px

  .hasClear &
    .size-xs&
      padding-right 20px
    .size-s&
      padding-right 24px
    .size-m&
      padding-right 34px
    .size-l&
      padding-right 36px
    .size-xl&
      padding-right 40px

  &::placeholder
    color var(--accent-color-alpha-500)

  &::selection
    background-color var(--active-color-alpha-300)

@-webkit-keyframes clearBg
  to
    background transparent

.isTextArea .control
  display block
  width 100%
  height 100%
  min-height 100%

  &:hover
    cursor text

  &::after
    display block
    content ''

.control[type=number]
  -moz-appearance textfield
  margin-right 14px

  // Chrome, Safari, Edge, Opera
  &::-webkit-outer-spin-button
  &::-webkit-inner-spin-button
    -webkit-appearance none

.numberArrows
  position absolute
  right 0
  display flex
  flex-direction column
  height 100%

  & > button
    min-height unset
    max-height unset
    height 50%
    width 50%
    padding-right 0
    padding-left 0
    background-color transparent !important
    opacity .5
    transition opacity .1s ease-out

    &:hover
      opacity 1

    .size-xs &
      min-width 'calc(%s * .8)' % $controlSizeXS
    .size-s &
      min-width 'calc(%s * .8)' % $controlSizeS
    .size-m &
      min-width 'calc(%s * .8)' % $controlSizeM
    .size-l &
      min-width 'calc(%s * .8)' % $controlSizeL
    .size-xl &
      min-width 'calc(%s * .8)' % $controlSizeXL

    & > svg
      transform scale(.8)

    &:first-child > svg
      margin-bottom -5%
    &:last-child > svg
      margin-top -5%


.isTextArea .control
.isTextArea .placeholder

  .size-xs&
    controlPaddingSize('xs')
    padding-top 6px
    padding-right 12px
    &::after
      height 6px
  .size-s&
    controlPaddingSize('s')
    padding-top 8px
    padding-right 16px
    &::after
      height 8px
  .size-m&
    controlPaddingSize('m')
    padding-top 10px
    padding-right 20px
    &::after
      height 10px
  .size-l&
    controlPaddingSize('l')
    padding-top 12px
    padding-right 24px
    &::after
      height 12px
  .size-xl&
    controlPaddingSize('xl')
    padding-top 14px
    padding-right 28px
    &::after
      height 14px

  padding-left 0 !important


.placeholder
  position absolute
  top 0
  left 0
  display inline-block
  max-width 100%
  padding inherit
  overflow hidden
  white-space nowrap
  text-overflow ellipsis
  opacity .4
  pointer-events none

.addonLeft
.addonRight
  display inline-flex
  align-items center
  flex-shrink 0
  z-index 1
  min-width 0 // to enable ellipsis work in flex
  user-select none

  // .size-s &
  //   min-width calc(var(--p-3) * 2)
  // .size-m &
  //   min-width calc(var(--p-5) * 2)
  // .size-l &
  //   min-width calc(var(--p-8) * 2)

  & > span
    white-space nowrap
    text-overflow ellipsis
    overflow hidden


.addonLeft
  .size-xs &
    margin-right calc(var(--p-2) / 2)
  .size-s &
    margin-right calc(var(--p-3) / 2)
  .size-m &
    margin-right calc(var(--p-5) / 2)
  .size-l &
    margin-right calc(var(--p-8) / 2)
  .size-xl &
    margin-right calc(var(--p-10) / 2)

.addonRight
  .size-xs &
    margin-left calc(var(--p-2) / 2)
  .size-s &
    margin-left calc(var(--p-3) / 2)
  .size-m &
    margin-left calc(var(--p-5) / 2)
  .size-l &
    margin-left calc(var(--p-8) / 2)
  .size-xl &
    margin-left calc(var(--p-10) / 2)

.requiredStar
  position absolute
  height 8px
  width 8px
  border-radius 50%
  background-color var(--warning-color)
  opacity .8
  pointer-events none

  .isDisabled &
    display none

  .size-xs &
    right 3px
    top 3px
  .size-s &
    right 4px
    top 4px
  .size-m &
    right 6px
    top 6px
  .size-l &
    right 8px
    top 8px
  .size-xl &
    right 10px
    top 10px

.isDisabled
  pointer-events none
  user-select none

.clearButton
  position absolute
  right 0
  top 0
  z-index 1
  bottom 1px
  height auto

  &:hover
    background-color var(--accent-color-alpha-0) !important

.clearIcon
  flex-shrink 0
  opacity .3
  transition opacity .2s ease-out

  .clearButton:hover &
    opacity .8

  .size-xs &
    height 8px
    width @height
  .size-s &
    height 10px
    width @height
  .size-m &
    height 12px
    width @height
  .size-l &
    height 14px
    width @height
  .size-xl &
    height 16px
    width @height

@supports (field-sizing: content)
  .root.fitContentWidth
    width fit-content
    max-width 100%

    .main
      width fit-content
      max-width 100%

    .controlWrapper
      flex 0 1 auto
      width fit-content
      max-width 100%

    .control
      flex-grow 0
      width auto
      max-width 100%
      field-sizing content
